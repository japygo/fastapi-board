# 테스트 전용 환경 설정 (Spring의 application-test.properties 역할)
APP_NAME="FastAPI 게시판 (테스트)"
DEBUG=True
SECRET_KEY=test-secret-key-for-testing-only
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 테스트용 인메모리 SQLite (Spring의 H2 인메모리 DB와 동일한 개념)
# 테스트 실행 시 DB가 메모리에 생성되고, 테스트 종료 후 자동으로 사라집니다
DATABASE_URL=sqlite:///:memory:
